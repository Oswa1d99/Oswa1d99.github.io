---
import { getInternalPath } from "../config/deployment";
import BaseLayout from "../layouts/BaseLayout.astro";
import { emptyStates } from "../config/site-content";
---

<BaseLayout
  title={emptyStates.pageNotFound.title}
  description={emptyStates.pageNotFound.description}
>
  <section class="reading-frame">
    <h1>{emptyStates.pageNotFound.title}</h1>
    <p>
      {emptyStates.pageNotFound.message}
    </p>
    <p>
      <a href={getInternalPath(emptyStates.pageNotFound.recordsHref)}>
        {emptyStates.pageNotFound.recordsAction}
      </a>
      {" / "}
      <a href={getInternalPath(emptyStates.pageNotFound.homeHref)}>
        {emptyStates.pageNotFound.homeAction}
      </a>
    </p>
  </section>
</BaseLayout>
