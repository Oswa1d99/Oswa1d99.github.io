---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Search" description="Search published Records.">
  <section class="records-frame">
    <h1>Search Records</h1>
    <label for="record-search">Search term</label>
    <input id="record-search" type="search" autocomplete="off" />
    <p class="meta" data-search-status></p>
    <div data-search-results></div>
  </section>
  <script>
    const input = document.querySelector("#record-search");
    const status = document.querySelector("[data-search-status]");
    const results = document.querySelector("[data-search-results]");
    let searchSequence = 0;

    async function loadPagefind() {
      try {
        const pagefindPath = "/pagefind/pagefind.js";
        return await import(/* @vite-ignore */ pagefindPath);
      } catch {
        if (status) {
          const fallbackLink = document.createElement("a");
          fallbackLink.setAttribute("href", "/records/");
          fallbackLink.textContent = "Browse Records";
          status.replaceChildren(
            "Search is unavailable. ",
            fallbackLink,
            " instead.",
          );
        }
        return null;
      }
    }

    const pagefindPromise = loadPagefind();

    function getRecordUrl(url: string) {
      try {
        const parsed = new URL(url, window.location.origin);
        if (
          parsed.origin === window.location.origin &&
          (parsed.pathname === "/records/" ||
            parsed.pathname.startsWith("/records/"))
        ) {
          return `${parsed.pathname}${parsed.search}${parsed.hash}`;
        }
      } catch {
        return null;
      }
      return null;
    }

    function appendSafeExcerpt(target: HTMLElement, excerpt: string) {
      const template = document.createElement("template");
      template.innerHTML = excerpt;

      function appendSafeNode(node: Node, parent: HTMLElement) {
        if (node.nodeType === Node.TEXT_NODE) {
          parent.append(document.createTextNode(node.textContent ?? ""));
          return;
        }

        if (
          node instanceof HTMLElement &&
          node.tagName.toLowerCase() === "mark"
        ) {
          const mark = document.createElement("mark");
          mark.textContent = node.textContent ?? "";
          parent.append(mark);
          return;
        }

        for (const child of node.childNodes) {
          appendSafeNode(child, parent);
        }
      }

      for (const child of template.content.childNodes) {
        appendSafeNode(child, target);
      }
    }

    function getResultTags(meta: Record<string, unknown>) {
      const tags = meta.tags;
      if (Array.isArray(tags)) {
        return tags.map((tag) => String(tag).trim()).filter(Boolean);
      }
      if (typeof tags === "string") {
        return tags
          .split(",")
          .map((tag) => tag.trim())
          .filter(Boolean);
      }
      return [];
    }

    function appendTags(target: HTMLElement, tags: string[]) {
      if (tags.length === 0) return;
      const list = document.createElement("ul");
      list.className = "tag-list";
      list.setAttribute("aria-label", "Tags");
      for (const tag of tags) {
        const item = document.createElement("li");
        const label = document.createElement("span");
        label.className = "tag";
        label.textContent = tag;
        item.append(label);
        list.append(item);
      }
      target.append(list);
    }

    function getResultDescription(meta: Record<string, unknown>) {
      return typeof meta.description === "string"
        ? meta.description.trim()
        : "";
    }

    input?.addEventListener("input", async (event) => {
      const sequence = ++searchSequence;
      const query =
        event.target instanceof HTMLInputElement
          ? event.target.value.trim()
          : "";
      if (!results || !status) return;
      results.replaceChildren();
      if (!query) {
        status.textContent = "";
        return;
      }
      const pagefind = await pagefindPromise;
      if (sequence !== searchSequence) return;
      if (!pagefind) return;
      const search = await pagefind.search(query);
      if (sequence !== searchSequence) return;
      const recordResults = [];
      for (const result of search.results) {
        const data = await result.data();
        if (sequence !== searchSequence) return;
        const recordUrl = getRecordUrl(data.url);
        if (recordUrl) {
          recordResults.push({ ...data, url: recordUrl });
        }
      }
      if (recordResults.length === 0) {
        status.textContent =
          "No records matched this search. Try a broader term.";
        return;
      }
      status.textContent = `${recordResults.length} result${
        recordResults.length === 1 ? "" : "s"
      }`;
      for (const data of recordResults) {
        const article = document.createElement("article");
        article.className = "record-card";
        const heading = document.createElement("h2");
        const link = document.createElement("a");
        const href = getRecordUrl(data.url);
        if (!href) continue;
        link.setAttribute("href", href);
        link.textContent = String(data.meta?.title ?? "Untitled record");
        heading.append(link);

        const tags = getResultTags(data.meta ?? {});
        const excerpt = document.createElement("p");
        if (typeof data.excerpt === "string" && data.excerpt.trim()) {
          appendSafeExcerpt(excerpt, data.excerpt);
        } else {
          excerpt.textContent = getResultDescription(data.meta ?? {});
        }

        article.append(heading);
        appendTags(article, tags);
        if (excerpt.textContent?.trim()) {
          article.append(excerpt);
        }
        results.appendChild(article);
      }
    });
  </script>
</BaseLayout>
