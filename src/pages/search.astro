---
import { getInternalPath, getPagefindAssetPath } from "../config/deployment";
import BaseLayout from "../layouts/BaseLayout.astro";
import { emptyStates, searchPage } from "../config/site-content";

const recordsPath = getInternalPath("/records/");
const buildPath = getInternalPath("/build/");
const pagefindAssetPath = getPagefindAssetPath();
const searchConfig = JSON.stringify({
  searchPage,
  emptyStates,
  pagefindAssetPath,
  recordsPath,
  buildPath,
}).replaceAll("<", "\\u003c");
---

<BaseLayout title={searchPage.title} description={searchPage.description}>
  <section class="records-frame search-page">
    <p class="eyebrow">{searchPage.eyebrow}</p>
    <h1>{searchPage.heading}</h1>
    <p class="search-page__intro">
      {searchPage.intro}
    </p>
    <div class="search-control">
      <label for="record-search">{searchPage.label}</label>
      <div class="search-input-row">
        <span class="prompt-marker" aria-hidden="true">&gt;</span>
        <input id="record-search" type="search" autocomplete="off" />
        <button class="search-clear" type="button" data-search-clear hidden>
          {searchPage.clear}
        </button>
      </div>
    </div>
    <p class="search-status" data-search-status></p>
    <nav
      class="search-start"
      aria-label="Search starting points"
      data-search-start
    >
      <p class="meta">{searchPage.suggestedPathLabel}</p>
      <a href={recordsPath}>{searchPage.browseRecords}</a>
    </nav>
    <div class="search-results" data-search-results></div>
  </section>
  <script
    is:inline
    type="application/json"
    id="search-config"
    set:html={searchConfig}
  />
  <script>
    import {
      getResultDescription,
      getResultTags,
      getSearchableContentUrl as getSourceSearchableContentUrl,
    } from "../lib/search/static-search";

    type SearchPageCopy = {
      fallbackAction: string;
      fallbackSuffix: string;
      statusSearching: string;
      resultSingular: string;
      resultPlural: string;
      untitledResult: string;
    };

    type EmptyStateCopy = {
      searchNoMatch: string;
      searchUnavailable: string;
    };

    type SearchConfig = {
      searchPage: SearchPageCopy;
      emptyStates: EmptyStateCopy;
      pagefindAssetPath: string;
      recordsPath: string;
      buildPath: string;
    };

    type PagefindData = {
      url: string;
      meta?: Record<string, unknown>;
      excerpt?: string;
    };

    type PagefindResult = {
      data(): Promise<PagefindData>;
    };

    type PagefindModule = {
      search(query: string): Promise<{ results: PagefindResult[] }>;
    };

    const config = JSON.parse(
      document.querySelector("#search-config")?.textContent ?? "{}",
    ) as SearchConfig;
    const {
      searchPage,
      emptyStates,
      pagefindAssetPath,
      recordsPath,
      buildPath,
    } = config;
    const input = document.querySelector("#record-search");
    const status = document.querySelector("[data-search-status]");
    const results = document.querySelector("[data-search-results]");
    const searchStart = document.querySelector("[data-search-start]");
    const clearButton = document.querySelector("[data-search-clear]");
    let searchSequence = 0;
    let pagefindPromise: Promise<PagefindModule | null> | null = null;

    async function loadPagefind(): Promise<PagefindModule | null> {
      try {
        if (import.meta.env.DEV) {
          throw new Error("Pagefind is generated during production build.");
        }
        const pagefindPath = pagefindAssetPath;
        return (await import(
          /* @vite-ignore */ pagefindPath
        )) as PagefindModule;
      } catch {
        if (status) {
          const fallbackLink = document.createElement("a");
          fallbackLink.setAttribute("href", recordsPath);
          fallbackLink.textContent = searchPage.fallbackAction;
          status.replaceChildren(
            `${emptyStates.searchUnavailable} `,
            fallbackLink,
            searchPage.fallbackSuffix,
          );
        }
        return null;
      }
    }

    function getPagefind() {
      pagefindPromise = pagefindPromise ?? loadPagefind();
      return pagefindPromise;
    }

    function getSearchableContentUrl(url: string) {
      try {
        const parsed = new URL(url, window.location.origin);
        const sourceUrl = getSourceSearchableContentUrl(
          parsed.href,
          window.location.origin,
        );
        if (sourceUrl?.startsWith("/records/")) {
          return `${recordsPath}${sourceUrl.slice("/records/".length)}`;
        }
        if (sourceUrl?.startsWith("/build/")) {
          return `${buildPath}${sourceUrl.slice("/build/".length)}`;
        }
        if (parsed.origin !== window.location.origin) return null;

        const searchableSections = [
          { deployedPath: recordsPath },
          { deployedPath: buildPath },
        ];
        for (const { deployedPath } of searchableSections) {
          if (
            parsed.pathname.startsWith(deployedPath) &&
            parsed.pathname !== deployedPath
          ) {
            return `${parsed.pathname}${parsed.search}${parsed.hash}`;
          }
        }
      } catch {
        return null;
      }
      return null;
    }

    function appendSafeExcerpt(target: Element, excerpt: string) {
      const template = document.createElement("template");
      template.innerHTML = excerpt;

      function appendSafeNode(node: ChildNode, parent: Element) {
        if (node.nodeType === Node.TEXT_NODE) {
          parent.append(document.createTextNode(node.textContent ?? ""));
          return;
        }

        if (
          node instanceof HTMLElement &&
          node.tagName.toLowerCase() === "mark"
        ) {
          const mark = document.createElement("mark");
          mark.textContent = node.textContent ?? "";
          parent.append(mark);
          return;
        }

        for (const child of node.childNodes) {
          appendSafeNode(child, parent);
        }
      }

      for (const child of template.content.childNodes) {
        appendSafeNode(child, target);
      }
    }

    function appendTags(target: Element, tags: string[]) {
      if (tags.length === 0) return;
      const list = document.createElement("ul");
      list.className = "tag-list";
      list.setAttribute("aria-label", "Tags");
      for (const tag of tags) {
        const item = document.createElement("li");
        const label = document.createElement("span");
        label.className = "tag";
        label.textContent = tag;
        item.append(label);
        list.append(item);
      }
      target.append(list);
    }

    clearButton?.addEventListener("click", () => {
      if (!(input instanceof HTMLInputElement)) return;
      input.value = "";
      input.dispatchEvent(new Event("input", { bubbles: true }));
      input.focus();
    });

    input?.addEventListener("input", async (event) => {
      const sequence = ++searchSequence;
      const query =
        event.target instanceof HTMLInputElement
          ? event.target.value.trim()
          : "";
      if (!results || !status) return;
      results.replaceChildren();
      clearButton?.toggleAttribute("hidden", !query);
      if (!query) {
        status.textContent = "";
        searchStart?.removeAttribute("hidden");
        return;
      }
      searchStart?.setAttribute("hidden", "");
      status.textContent = searchPage.statusSearching;
      const pagefind = await getPagefind();
      if (sequence !== searchSequence) return;
      if (!pagefind) return;
      const search = await pagefind.search(query);
      if (sequence !== searchSequence) return;
      const recordResults = [];
      for (const result of search.results) {
        const data = await result.data();
        if (sequence !== searchSequence) return;
        const contentUrl = getSearchableContentUrl(data.url);
        if (contentUrl) {
          recordResults.push({ ...data, url: contentUrl });
        }
      }
      if (recordResults.length === 0) {
        status.textContent = emptyStates.searchNoMatch;
        return;
      }
      const resultLabel =
        recordResults.length === 1
          ? searchPage.resultSingular
          : searchPage.resultPlural;
      status.textContent = `${recordResults.length} ${resultLabel}`;
      for (const data of recordResults) {
        const article = document.createElement("article");
        article.className = "record-card";
        const heading = document.createElement("h2");
        const link = document.createElement("a");
        const href = getSearchableContentUrl(data.url);
        if (!href) continue;
        link.setAttribute("href", href);
        link.textContent = String(
          data.meta?.title ?? searchPage.untitledResult,
        );
        heading.append(link);

        const tags = getResultTags(data.meta ?? {});
        const excerpt = document.createElement("p");
        if (typeof data.excerpt === "string" && data.excerpt.trim()) {
          appendSafeExcerpt(excerpt, data.excerpt);
        } else {
          excerpt.textContent = getResultDescription(data.meta ?? {});
        }

        article.append(heading);
        appendTags(article, tags);
        if (excerpt.textContent?.trim()) {
          article.append(excerpt);
        }
        results.appendChild(article);
      }
    });
  </script>
</BaseLayout>
