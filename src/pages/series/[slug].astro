---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RecordsView from "../../components/RecordsView.astro";
import { emptyStates } from "../../config/site-content";
import {
  getSeriesPageContent,
  getSeriesStaticPaths,
} from "../../lib/content/graph";

export async function getStaticPaths() {
  return getSeriesStaticPaths();
}

const { series } = Astro.props;
const seriesView = await getSeriesPageContent(series.id);
---

<BaseLayout title={series.data.title} description={series.data.description}>
  <RecordsView
    title={series.data.title}
    description={series.data.description}
    records={seriesView.records}
    emptyState={emptyStates.seriesNoRecords}
  />
</BaseLayout>
