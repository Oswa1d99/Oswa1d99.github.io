---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RecordsView from "../../components/RecordsView.astro";
import { emptyStates } from "../../config/site-content";
import { tagSlugs } from "../../config/tags";
import { getTagPageContent } from "../../lib/content/graph";

export function getStaticPaths() {
  return tagSlugs.map((tag) => ({ params: { tag } }));
}

const tag = Astro.params.tag ?? "";
const tagView = await getTagPageContent(tag);
---

<BaseLayout
  title={tagView.label}
  description={`Records tagged ${tagView.label}.`}
>
  <RecordsView
    title={tagView.label}
    records={tagView.records}
    emptyState={emptyStates.tagNoRecords}
  />
</BaseLayout>
