---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RecordsView from "../../components/RecordsView.astro";
import { emptyStates } from "../../config/site-content";
import { getAllRecordListItems } from "../../lib/content/graph";
import { sortRecordItems } from "../../lib/content/records-discovery";

const records = sortRecordItems(await getAllRecordListItems(), "newest");
---

<BaseLayout
  title="Records"
  description="Writing, study notes, engineering memos, project logs, and reflections."
>
  <RecordsView
    title="Records"
    description="Writing, study notes, engineering memos, project logs, and reflections."
    records={records}
    emptyState={emptyStates.recordsNoPublished}
    filters
  />
</BaseLayout>
