---
import { render } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";
import { getBuildStaticPaths } from "../../lib/content/graph";
import { getContentPageMeta } from "../../lib/rendering/content-page";

export async function getStaticPaths() {
  return getBuildStaticPaths();
}

const { build } = Astro.props;
const { Content } = await render(build);
const contentMeta = getContentPageMeta({
  title: build.data.title,
  description: build.data.description,
  date: build.data.updatedAt,
  tags: build.data.tags,
  body: build.body,
});
---

<ContentLayout
  title={contentMeta.title}
  description={contentMeta.description}
  date={contentMeta.date}
  tags={contentMeta.tags}
  hasMermaid={contentMeta.hasMermaid}
>
  <Content />
</ContentLayout>
