---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BuildSummary from "../../components/BuildSummary.astro";
import EmptyState from "../../components/EmptyState.astro";
import { emptyStates } from "../../config/site-content";
import { getBuildOverviewContent } from "../../lib/content/graph";

const builds = await getBuildOverviewContent();
---

<BaseLayout title="Build" description="One focused public build thread.">
  <section class="page-frame">
    <h1>Build</h1>
    <p>
      A focused open-source build thread: what is being built, why it matters,
      current status, and related Records.
    </p>
    {
      builds.length > 0 ? (
        builds.map((item) => <BuildSummary item={item} />)
      ) : (
        <EmptyState
          title={emptyStates.buildNoPublicThread.title}
          message={emptyStates.buildNoPublicThread.message}
          href={emptyStates.buildNoPublicThread.href}
          action={emptyStates.buildNoPublicThread.action}
        />
      )
    }
  </section>
</BaseLayout>
