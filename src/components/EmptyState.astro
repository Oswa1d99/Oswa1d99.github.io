---
import { getDeployableHref } from "../config/deployment";

interface Props {
  title: string;
  message: string;
  href?: string;
  action?: string;
}

const { title, message, href, action } = Astro.props;
const deployableHref = href ? getDeployableHref(href) : undefined;
---

<section class="empty-state" aria-label={title}>
  <h2>{title}</h2>
  <p>{message}</p>
  {
    href && action ? (
      <p>
        <a href={deployableHref}>{action}</a>
      </p>
    ) : null
  }
</section>
