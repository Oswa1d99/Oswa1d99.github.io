---
import TagList from "./TagList.astro";
import { getInternalPath } from "../config/deployment";
import type { RecordListItem } from "../lib/content/graph";

interface Props {
  records: RecordListItem[];
  headingLevel?: "h2" | "h3";
  tagLimit?: number;
}

const { records, headingLevel = "h2", tagLimit } = Astro.props;
const Heading = headingLevel;
---

<ul class="record-list">
  {
    records.map((record) => (
      <li class="record-card" data-record-card={record.id}>
        <p class="meta">
          <time datetime={record.publishedAt.toISOString()}>
            {record.publishedAt.toISOString().slice(0, 10)}
          </time>
          {record.primaryLabel ? ` / ${record.primaryLabel}` : ""}
        </p>
        <Heading>
          <a href={getInternalPath(record.href)}>{record.title}</a>
        </Heading>
        <p>{record.description}</p>
        {tagLimit === undefined || tagLimit > 0 ? (
          <TagList
            tags={
              tagLimit === undefined
                ? record.tags
                : record.tags.slice(0, tagLimit)
            }
          />
        ) : null}
      </li>
    ))
  }
</ul>
<script
  is:inline
  type="application/json"
  data-record-discovery
  set:html={JSON.stringify(
    records.map((record) => ({
      id: record.id,
      tags: record.tags,
      formatTag: record.formatTag ?? "",
      publishedAt: record.publishedAt.toISOString(),
    })),
  )}
/>
