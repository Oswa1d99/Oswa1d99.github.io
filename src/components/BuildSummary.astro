---
import TagList from "./TagList.astro";
import { getInternalPath } from "../config/deployment";
import type { BuildSummaryItem } from "../lib/content/graph";

interface Props {
  item: BuildSummaryItem;
}

const {
  item: { build, relatedRecords },
} = Astro.props;
---

<section class="build-panel">
  <p class="meta">
    {build.status} / updated {build.updatedAt.toISOString().slice(0, 10)}
  </p>
  <h2>
    <a href={getInternalPath(build.href)}>{build.title}</a>
  </h2>
  <p>{build.description}</p>
  <TagList tags={build.tags} />
  <div>
    <h3>What works now</h3>
    <p>
      The public build thread frames the problem, current status, and related
      Records. Deeper implementation artifacts will appear only when they are
      real.
    </p>
  </div>
  {
    relatedRecords.length > 0 ? (
      <div>
        <h3>Related Records</h3>
        <ul>
          {relatedRecords.map((record) => (
            <li>
              <a href={getInternalPath(record.href)}>{record.title}</a>
            </li>
          ))}
        </ul>
      </div>
    ) : null
  }
  <p>
    {build.githubUrl ? <a href={build.githubUrl}>GitHub</a> : null}
    {
      build.demoUrl ? (
        <>
          {" "}
          / <a href={build.demoUrl}>Demo</a>
        </>
      ) : null
    }
  </p>
</section>
