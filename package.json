{
  "name": "jaybaek-dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "astro": "astro",
    "build": "astro build && if find dist -name '*.html' -type f | grep -q .; then pagefind --site dist; else echo 'No HTML files found; skipping Pagefind.'; fi",
    "preview": "astro preview",
    "format": "prettier --write .",
    "lint": "prettier --check ."
  },
  "dependencies": {
    "astro": "6.1.10",
    "mermaid": "11.14.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "pagefind": "1.5.2",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
